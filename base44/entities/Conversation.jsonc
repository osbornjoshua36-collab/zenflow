{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "business_id": {
      "type": "string",
      "description": "FK to Business (seller)"
    },
    "listing_id": {
      "type": "string"
    },
    "quote_id": {
      "type": "string"
    },
    "buyer_name": {
      "type": "string"
    },
    "buyer_email": {
      "type": "string"
    },
    "buyer_phone": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Open",
        "Closed",
        "Archived"
      ],
      "default": "Open"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "business_id",
    "buyer_name",
    "buyer_email",
    "status"
  ]
}