{
  "name": "Business",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Business name (legacy field)"
    },
    "business_name": {
      "type": "string",
      "description": "Business display name"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly unique identifier, e.g. smiths-plumbing-co"
    },
    "owner_first_name": {
      "type": "string"
    },
    "owner_last_name": {
      "type": "string"
    },
    "owner_email": {
      "type": "string",
      "format": "email",
      "description": "Owner email for notifications and login"
    },
    "owner_phone": {
      "type": "string",
      "description": "Owner primary phone number"
    },
    "business_phone": {
      "type": "string",
      "description": "Public-facing business phone (shown on storefront only if verified)"
    },
    "business_address_line1": {
      "type": "string"
    },
    "business_address_line2": {
      "type": "string"
    },
    "business_city": {
      "type": "string"
    },
    "business_state": {
      "type": "string",
      "description": "2-letter state code, e.g. NC"
    },
    "business_zip": {
      "type": "string"
    },
    "years_in_business": {
      "type": "integer",
      "minimum": 0
    },
    "number_of_employees": {
      "type": "integer",
      "minimum": 1
    },
    "business_description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Full business description shown on storefront"
    },
    "tagline": {
      "type": "string",
      "maxLength": 120,
      "description": "Short headline shown on public storefront"
    },
    "industry": {
      "type": "string",
      "enum": [
        "HVAC",
        "Plumbing",
        "Electrical",
        "Salon",
        "Real Estate",
        "Cleaning",
        "Landscaping",
        "Other"
      ],
      "description": "Service business type"
    },
    "phone": {
      "type": "string",
      "description": "Legacy phone field \u2014 used for identity verification"
    },
    "phone_verified": {
      "type": "boolean",
      "default": false
    },
    "ai_tone": {
      "type": "string",
      "enum": [
        "Professional",
        "Friendly",
        "Casual",
        "Formal"
      ],
      "description": "AI persona tone for messages"
    },
    "timezone": {
      "type": "string",
      "description": "Business timezone, e.g. America/New_York"
    },
    "logo_url": {
      "type": "string",
      "description": "Business logo URL (JPG/PNG/SVG)"
    },
    "banner_image_url": {
      "type": "string",
      "description": "Storefront header banner image URL (JPG/PNG), 1200x300px recommended"
    },
    "portfolio_images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 12,
      "description": "Array of portfolio image URLs, max 12"
    },
    "service_radius_miles": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 25,
      "description": "Miles the seller will travel from their location"
    },
    "service_area_description": {
      "type": "string",
      "maxLength": 300,
      "description": "Free-text description of service area"
    },
    "is_verified": {
      "type": "boolean",
      "default": false,
      "description": "Set by admin only \u2014 unlocks phone display and verified badge",
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "unsubmitted",
        "pending",
        "approved",
        "rejected"
      ],
      "default": "unsubmitted",
      "description": "Credential verification state",
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "verification_note": {
      "type": "string",
      "description": "Internal admin note about verification"
    },
    "licence_number": {
      "type": "string"
    },
    "licence_type": {
      "type": "string"
    },
    "licence_expiry_date": {
      "type": "string",
      "format": "date"
    },
    "licence_document_url": {
      "type": "string",
      "description": "Uploaded licence document URL (PDF or image)"
    },
    "insurance_provider": {
      "type": "string"
    },
    "insurance_policy_number": {
      "type": "string"
    },
    "insurance_expiry_date": {
      "type": "string",
      "format": "date"
    },
    "insurance_document_url": {
      "type": "string",
      "description": "Uploaded insurance document URL (PDF)"
    },
    "onboarding_status": {
      "type": "string",
      "enum": [
        "incomplete",
        "ready_to_launch",
        "active",
        "suspended"
      ],
      "default": "incomplete",
      "description": "Current onboarding / account state"
    },
    "onboarding_step_completed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 6,
      "default": 0,
      "description": "Furthest onboarding step the seller has completed (0\u20136)"
    },
    "onboarding_intent": {
      "type": "string",
      "enum": [
        "leads",
        "profile",
        "operations"
      ],
      "description": "Seller's stated goal \u2014 set once at intent screen, never overwritten"
    },
    "onboarding_completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when seller clicked Go live"
    },
    "wizard_last_seen_at": {
      "type": "string",
      "format": "date-time",
      "description": "Updated each time the wizard screen loads \u2014 used for re-entry resumption"
    },
    "profile_completeness_pct": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 0,
      "description": "Calculated 0-100 profile completeness score"
    },
    "is_accepting_jobs": {
      "type": "boolean",
      "default": true,
      "description": "Whether the business is accepting new job requests"
    },
    "go_live_date": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when onboarding_status first became active"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Paused",
        "Setup"
      ],
      "description": "Legacy business account status"
    },
    "subscription_tier": {
      "type": "string",
      "enum": [
        "none",
        "starter",
        "pro",
        "business"
      ],
      "default": "none"
    },
    "subscription_plan": {
      "type": "string",
      "description": "Current active subscription plan (starter, pro, business) \u2014 set by payment processor or admin only",
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "subscription_start_date": {
      "type": "string",
      "format": "date"
    },
    "subscription_end_date": {
      "type": "string",
      "format": "date-time",
      "description": "Current billing period end / cancellation revert date"
    },
    "subscription_status": {
      "type": "string",
      "enum": [
        "inactive",
        "active",
        "past_due",
        "cancelled",
        "trial",
        "expired"
      ],
      "default": "inactive",
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "subscription_plan_id": {
      "type": "string",
      "description": "Base44 Payments plan identifier",
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "base44_subscription_id": {
      "type": "string",
      "description": "Unique subscription contract ID from Base44 Payments",
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "trial_plan_tier": {
      "type": "string",
      "enum": [
        "none",
        "starter",
        "pro",
        "business"
      ],
      "default": "none",
      "description": "The tier the seller selected for their free trial"
    },
    "trial_started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Set when seller confirms trial selection"
    },
    "trial_ends_at": {
      "type": "string",
      "format": "date-time",
      "description": "Set to trial_started_at + 14 days"
    },
    "is_founding_member": {
      "type": "boolean",
      "default": false,
      "description": "Set to true permanently when seller goes live while active seller count is below 200. Locks in founding member pricing forever.",
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "locked_subscription_price": {
      "type": "number",
      "description": "The monthly price locked in at time of founding member activation. Never changes once set.",
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    }
  },
  "required": [
    "business_name",
    "slug",
    "owner_first_name",
    "owner_last_name",
    "owner_email",
    "owner_phone",
    "business_address_line1",
    "business_city",
    "business_state",
    "business_zip",
    "service_radius_miles"
  ]
}